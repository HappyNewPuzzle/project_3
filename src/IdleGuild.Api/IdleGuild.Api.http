@IdleGuild.Api_HostAddress = http://localhost:5219

GET {{IdleGuild.Api_HostAddress}}/health
Accept: text/plain

###

GET {{IdleGuild.Api_HostAddress}}/api/v1/system/status
Accept: application/json

###

POST {{IdleGuild.Api_HostAddress}}/api/v1/accounts/guest
Accept: application/json

###

@AccessToken = paste_guest_access_token_here

GET {{IdleGuild.Api_HostAddress}}/api/v1/game-state
Authorization: Bearer {{AccessToken}}
Accept: application/json

###

POST {{IdleGuild.Api_HostAddress}}/api/v1/rewards/idle/claim
Authorization: Bearer {{AccessToken}}
Idempotency-Key: idle-claim-001
Accept: application/json

###

POST {{IdleGuild.Api_HostAddress}}/api/v1/heroes/main/upgrade
Authorization: Bearer {{AccessToken}}
Idempotency-Key: hero-upgrade-001
Accept: application/json

###
