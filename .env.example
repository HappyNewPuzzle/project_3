# 로컬 개발 전용 값이며 실제 운영 비밀번호로 사용하지 않습니다.
POSTGRES_DB=idleguild
POSTGRES_USER=idleguild
POSTGRES_PASSWORD=replace_with_local_password
POSTGRES_PORT=5432

# API 실행 시 PowerShell 환경 변수 Jwt__SigningKey로 주입할 로컬 예시입니다.
JWT_SIGNING_KEY=replace_with_a_random_secret_of_at_least_32_bytes
JWT_ISSUER=IdleGuild.Api
JWT_AUDIENCE=IdleGuild.Client
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=1440
API_PORT=5219
